# Example environment variables for JSON Comparator
# Copy this file to .env.local and fill in your values

# API URL (if you need to call external APIs)
REACT_APP_API_URL=

# App configuration
REACT_APP_APP_NAME=JSON Comparator
REACT_APP_VERSION=0.1.0

# Feature flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG=false